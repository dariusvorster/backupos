DATABASE_URL=file:./data/backupos.db

# Required — generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-32-chars-minimum-here!!

# Required — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-32-chars-minimum-here!!

# Required — URL where BackupOS is accessible (used for auth callbacks)
BETTER_AUTH_URL=http://localhost:3000

# Restic binary path (optional — defaults to 'restic' in PATH)
RESTIC_BINARY_PATH=/usr/local/bin/restic

# Optional — Resend API key for email alerts
RESEND_API_KEY=
ALERT_TO_EMAIL=you@example.com
