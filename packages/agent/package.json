{
  "name": "@backupos/agent",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/agent.js",
  "bin": {
    "backupos-agent": "./dist/agent.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/agent.ts --bundle --platform=node --target=node18 --format=cjs --outfile=../../apps/web/public/agent/bundle.js",
    "start": "node dist/agent.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@backupos/agent-protocol": "workspace:*",
    "@backupos/engine": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
