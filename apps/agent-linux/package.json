{
  "name": "@backupos/agent-linux",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:x64":        "bun build src/index.ts --compile --outfile dist/backupos-agent-linux-x64      --target bun-linux-x64",
    "build:arm64":      "bun build src/index.ts --compile --outfile dist/backupos-agent-linux-arm64   --target bun-linux-arm64",
    "build:darwin-x64":   "bun build src/index.ts --compile --outfile dist/backupos-agent-darwin-x64   --target bun-darwin-x64",
    "build:darwin-arm64": "bun build src/index.ts --compile --outfile dist/backupos-agent-darwin-arm64 --target bun-darwin-arm64",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@backupos/agent-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
